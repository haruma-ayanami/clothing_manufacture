<Page x:Class="clothing_manufacture.Views.ProcessStagesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Этапы процесса"
      Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <ResourceDictionary Source="/Resources/AppStyles.xaml"/>
    </Page.Resources>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderCardStyle}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Обновить"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="110"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock Text="Этапы процесса" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Этапы внутри производственных и организационных процессов." Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="390" MinWidth="350" MaxWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Список" Style="{StaticResource SectionTitleStyle}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ProcessStages}"
                              SelectedItem="{Binding SelectedProcessStage, Mode=TwoWay}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="70"
                                                MinWidth="60"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Процесс"
                                                Binding="{Binding Process.Name}"
                                                Width="230"
                                                MinWidth="170"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Номер этапа"
                                                Binding="{Binding StageNumber}"
                                                Width="130"
                                                MinWidth="100"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Наименование"
                                                Binding="{Binding Name}"
                                                Width="240"
                                                MinWidth="180"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Результат"
                                                Binding="{Binding Result}"
                                                Width="300"
                                                MinWidth="220"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Форма" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Процесс" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ProductionProcesses}"
                                      SelectedItem="{Binding SelectedProductionProcess, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Наименование" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" MaxLength="200"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Номер этапа" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormStageNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Описание" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}" MaxLength="1000" Height="80"
                                     Style="{StaticResource AppMultilineTextBoxStyle}"/>

                            <TextBlock Text="Входные данные" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormInputData, UpdateSourceTrigger=PropertyChanged}" MaxLength="1000" Height="80"
                                     Style="{StaticResource AppMultilineTextBoxStyle}"/>

                            <TextBlock Text="Результат" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormResult, UpdateSourceTrigger=PropertyChanged}" MaxLength="1000" Height="80"
                                     Style="{StaticResource AppMultilineTextBoxStyle}"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Добавить"
                                        Command="{Binding AddCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"/>

                                <Button Content="Изменить"
                                        Command="{Binding UpdateCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>

                                <Button Content="Удалить"
                                        Command="{Binding DeleteCommand}"
                                        Style="{StaticResource DangerButtonStyle}"/>

                                <Button Content="Очистить"
                                        Command="{Binding ClearCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StatusBorderStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
