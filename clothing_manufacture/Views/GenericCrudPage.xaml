<Page x:Class="clothing_manufacture.Views.GenericCrudPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <DataTemplate x:Key="TextFieldTemplate">
            <TextBox Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="{Binding Definition.MaxLength}"/>
        </DataTemplate>

        <DataTemplate x:Key="MultilineFieldTemplate">
            <TextBox Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="{Binding Definition.MaxLength}"
                     Height="82"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"/>
        </DataTemplate>

        <DataTemplate x:Key="IntegerFieldTemplate">
            <TextBox Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <DataTemplate x:Key="DecimalFieldTemplate">
            <TextBox Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <DataTemplate x:Key="DateFieldTemplate">
            <DatePicker SelectedDate="{Binding DateValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <DataTemplate x:Key="CheckboxFieldTemplate">
            <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Content="Да"
                      VerticalAlignment="Center"
                      Margin="0 8 0 0"/>
        </DataTemplate>

        <DataTemplate x:Key="ChoiceFieldTemplate">
            <ComboBox ItemsSource="{Binding Options}"
                      DisplayMemberPath="Text"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <DataTemplate x:Key="LookupFieldTemplate">
            <ComboBox ItemsSource="{Binding Options}"
                      DisplayMemberPath="Text"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      IsTextSearchEnabled="True"/>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0 0 0 14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource PageDescriptionStyle}" Margin="0 4 0 0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Обновить" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Content="Очистить" Command="{Binding ClearCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" MinWidth="560"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="440" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Список записей" FontSize="18" FontWeight="SemiBold" Margin="6 0 0 10"/>

                    <DataGrid x:Name="ItemsDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D8E0EC"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Padding="18 16 18 12" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0 0 0 1">
                        <StackPanel>
                            <TextBlock Text="Форма записи" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Поля со звёздочкой обязательны" Foreground="{StaticResource TextBrushMuted}" Margin="0 3 0 0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18">
                        <ItemsControl ItemsSource="{Binding Fields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0 0 0 14">
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Margin="0 0 0 5"/>
                                        <ContentControl Content="{Binding}">
                                            <ContentControl.Style>
                                                <Style TargetType="ContentControl">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource TextFieldTemplate}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ControlKind}" Value="Text">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource TextFieldTemplate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ControlKind}" Value="Multiline">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource MultilineFieldTemplate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ControlKind}" Value="Integer">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource IntegerFieldTemplate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ControlKind}" Value="Decimal">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource DecimalFieldTemplate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ControlKind}" Value="Date">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource DateFieldTemplate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ControlKind}" Value="Checkbox">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource CheckboxFieldTemplate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ControlKind}" Value="Choice">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource ChoiceFieldTemplate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ControlKind}" Value="Lookup">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource LookupFieldTemplate}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentControl.Style>
                                        </ContentControl>
                                        <TextBlock Text="{Binding HelpText}" Foreground="{StaticResource TextBrushMuted}" FontSize="12" TextWrapping="Wrap" Margin="0 4 0 0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="18 12 18 16" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0 1 0 0">
                        <WrapPanel>
                            <Button Content="Добавить" Command="{Binding AddCommand}"/>
                            <Button Content="Сохранить" Command="{Binding UpdateCommand}"/>
                            <Button Content="Удалить" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButtonStyle}"/>
                        </WrapPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12" Margin="0 14 0 0">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
