<Page x:Class="clothing_manufacture.Views.CustomerOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы клиентов"
      Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <ResourceDictionary Source="/Resources/AppStyles.xaml"/>
    </Page.Resources>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderCardStyle}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Обновить"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="110"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock Text="Заказы клиентов" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Заказы клиентов, сроки, менеджеры и комментарии." Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="390" MinWidth="350" MaxWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Список" Style="{StaticResource SectionTitleStyle}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CustomerOrders}"
                              SelectedItem="{Binding SelectedCustomerOrder, Mode=TwoWay}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="70"
                                                MinWidth="60"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Номер заказа"
                                                Binding="{Binding OrderNumber}"
                                                Width="170"
                                                MinWidth="130"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Клиент"
                                                Binding="{Binding Client.Name}"
                                                Width="250"
                                                MinWidth="180"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Дата заказа"
                                                Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                Width="140"
                                                MinWidth="110"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Срок"
                                                Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                Width="140"
                                                MinWidth="110"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Статус"
                                                Binding="{Binding Status}"
                                                Width="130"
                                                MinWidth="100"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Менеджер"
                                                Binding="{Binding ManagerEmployee.Person.FullName}"
                                                Width="250"
                                                MinWidth="180"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Форма" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Номер заказа" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormOrderNumber, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Клиент" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Clients}"
                                      SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Дата заказа" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding FormOrderDate, Mode=TwoWay}"
                                        Style="{StaticResource AppDatePickerStyle}"/>

                            <TextBlock Text="Срок исполнения" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding FormDueDate, Mode=TwoWay}"
                                        Style="{StaticResource AppDatePickerStyle}"/>

                            <TextBlock Text="Менеджер" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Employees}"
                                      SelectedItem="{Binding SelectedManagerEmployee, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormStatus, UpdateSourceTrigger=PropertyChanged}" MaxLength="50"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Требования к брендированию" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormBrandingRequirements, UpdateSourceTrigger=PropertyChanged}" MaxLength="1000" Height="90"
                                     Style="{StaticResource AppMultilineTextBoxStyle}"/>

                            <TextBlock Text="Комментарий" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormComment, UpdateSourceTrigger=PropertyChanged}" MaxLength="1000" Height="90"
                                     Style="{StaticResource AppMultilineTextBoxStyle}"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Добавить"
                                        Command="{Binding AddCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"/>

                                <Button Content="Изменить"
                                        Command="{Binding UpdateCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>

                                <Button Content="Удалить"
                                        Command="{Binding DeleteCommand}"
                                        Style="{StaticResource DangerButtonStyle}"/>

                                <Button Content="Очистить"
                                        Command="{Binding ClearCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StatusBorderStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
