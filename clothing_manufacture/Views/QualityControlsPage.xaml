<Page x:Class="clothing_manufacture.Views.QualityControlsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Контроль качества"
      Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <ResourceDictionary Source="/Resources/AppStyles.xaml"/>
    </Page.Resources>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderCardStyle}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Обновить"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="110"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock Text="Контроль качества" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Проверки качества образцов и производственных партий." Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="390" MinWidth="350" MaxWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Список" Style="{StaticResource SectionTitleStyle}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding QualityControls}"
                              SelectedItem="{Binding SelectedQualityControl, Mode=TwoWay}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="70"
                                                MinWidth="60"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Дата контроля"
                                                Binding="{Binding ControlDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                Width="150"
                                                MinWidth="120"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Тип контроля"
                                                Binding="{Binding ControlType}"
                                                Width="190"
                                                MinWidth="150"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Результат"
                                                Binding="{Binding Result}"
                                                Width="140"
                                                MinWidth="110"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Партия"
                                                Binding="{Binding ProductionBatch.BatchNumber}"
                                                Width="170"
                                                MinWidth="130"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Образец"
                                                Binding="{Binding Sample.Id}"
                                                Width="100"
                                                MinWidth="80"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Контролёр"
                                                Binding="{Binding ControllerEmployee.Person.FullName}"
                                                Width="250"
                                                MinWidth="180"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Форма" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Дата контроля" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding FormControlDate, Mode=TwoWay}"
                                        Style="{StaticResource AppDatePickerStyle}"/>

                            <TextBlock Text="Тип контроля" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormControlType, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Результат" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormResult, UpdateSourceTrigger=PropertyChanged}" MaxLength="50"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Производственная партия" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ProductionBatches}"
                                      SelectedItem="{Binding SelectedProductionBatch, Mode=TwoWay}"
                                      DisplayMemberPath="BatchNumber"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Образец" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Samples}"
                                      SelectedItem="{Binding SelectedSample, Mode=TwoWay}"
                                      DisplayMemberPath="Id"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Контролёр" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Employees}"
                                      SelectedItem="{Binding SelectedControllerEmployee, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Замечания" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}" MaxLength="1000" Height="90"
                                     Style="{StaticResource AppMultilineTextBoxStyle}"/>

                            <TextBlock Text="Решение" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormDecision, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Добавить"
                                        Command="{Binding AddCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"/>

                                <Button Content="Изменить"
                                        Command="{Binding UpdateCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>

                                <Button Content="Удалить"
                                        Command="{Binding DeleteCommand}"
                                        Style="{StaticResource DangerButtonStyle}"/>

                                <Button Content="Очистить"
                                        Command="{Binding ClearCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StatusBorderStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
