<Page x:Class="clothing_manufacture.Views.WarehouseStocksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Складские остатки"
      Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <ResourceDictionary Source="/Resources/AppStyles.xaml"/>
    </Page.Resources>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderCardStyle}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Обновить"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="110"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock Text="Складские остатки" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Остатки материалов и готовых изделий по складским ячейкам." Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="390" MinWidth="350" MaxWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Список" Style="{StaticResource SectionTitleStyle}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding WarehouseStocks}"
                              SelectedItem="{Binding SelectedWarehouseStock, Mode=TwoWay}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="70"
                                                MinWidth="60"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Ячейка"
                                                Binding="{Binding WarehouseCell.DisplayName}"
                                                Width="260"
                                                MinWidth="190"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Материал"
                                                Binding="{Binding Material.Name}"
                                                Width="230"
                                                MinWidth="170"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Вариант модели"
                                                Binding="{Binding ModelVariant.DisplayName}"
                                                Width="320"
                                                MinWidth="230"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Количество"
                                                Binding="{Binding Quantity}"
                                                Width="130"
                                                MinWidth="100"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Дата обновления"
                                                Binding="{Binding UpdateDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                Width="150"
                                                MinWidth="120"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Форма" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Складская ячейка" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding WarehouseCells}"
                                      SelectedItem="{Binding SelectedWarehouseCell, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Материал" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Materials}"
                                      SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Вариант модели" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ModelVariants}"
                                      SelectedItem="{Binding SelectedModelVariant, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Количество" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormQuantity, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Дата обновления" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding FormUpdateDate, Mode=TwoWay}"
                                        Style="{StaticResource AppDatePickerStyle}"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Добавить"
                                        Command="{Binding AddCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"/>

                                <Button Content="Изменить"
                                        Command="{Binding UpdateCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>

                                <Button Content="Удалить"
                                        Command="{Binding DeleteCommand}"
                                        Style="{StaticResource DangerButtonStyle}"/>

                                <Button Content="Очистить"
                                        Command="{Binding ClearCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StatusBorderStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
