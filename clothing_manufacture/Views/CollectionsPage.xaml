<Page x:Class="clothing_manufacture.Views.CollectionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Коллекции"
      Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <ResourceDictionary Source="/Resources/AppStyles.xaml"/>
    </Page.Resources>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderCardStyle}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Обновить"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="110"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock Text="Коллекции" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Коллекции, сезоны и связь с ассортиментным планом." Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="390" MinWidth="350" MaxWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Список" Style="{StaticResource SectionTitleStyle}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Collections}"
                              SelectedItem="{Binding SelectedCollection, Mode=TwoWay}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="70"
                                                MinWidth="60"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Наименование"
                                                Binding="{Binding Name}"
                                                Width="240"
                                                MinWidth="180"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Сезон"
                                                Binding="{Binding Season}"
                                                Width="140"
                                                MinWidth="110"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Год"
                                                Binding="{Binding Year}"
                                                Width="90"
                                                MinWidth="70"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Ценовой сегмент"
                                                Binding="{Binding PriceSegment}"
                                                Width="170"
                                                MinWidth="130"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Статус"
                                                Binding="{Binding Status}"
                                                Width="140"
                                                MinWidth="110"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Ассортиментный план"
                                                Binding="{Binding AssortmentPlan.PlanNumber}"
                                                Width="210"
                                                MinWidth="160"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Форма" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Наименование" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" MaxLength="200"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Сезон" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormSeason, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Год" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormYear, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Ценовой сегмент" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormPriceSegment, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormStatus, UpdateSourceTrigger=PropertyChanged}" MaxLength="50"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Ассортиментный план" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding AssortmentPlans}"
                                      SelectedItem="{Binding SelectedAssortmentPlan, Mode=TwoWay}"
                                      DisplayMemberPath="PlanNumber"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Добавить"
                                        Command="{Binding AddCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"/>

                                <Button Content="Изменить"
                                        Command="{Binding UpdateCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>

                                <Button Content="Удалить"
                                        Command="{Binding DeleteCommand}"
                                        Style="{StaticResource DangerButtonStyle}"/>

                                <Button Content="Очистить"
                                        Command="{Binding ClearCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StatusBorderStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
