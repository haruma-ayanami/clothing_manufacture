<Page x:Class="clothing_manufacture.Views.ModelMaterialsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Материалы модели"
      Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <ResourceDictionary Source="/Resources/AppStyles.xaml"/>
    </Page.Resources>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderCardStyle}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Обновить"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="110"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock Text="Материалы модели" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Состав модели: материал, расход и признак основного материала." Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="390" MinWidth="350" MaxWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Список" Style="{StaticResource SectionTitleStyle}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ModelMaterials}"
                              SelectedItem="{Binding SelectedModelMaterial, Mode=TwoWay}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="70"
                                                MinWidth="60"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Модель"
                                                Binding="{Binding Model.DisplayName}"
                                                Width="300"
                                                MinWidth="220"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Материал"
                                                Binding="{Binding Material.Name}"
                                                Width="250"
                                                MinWidth="180"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Кол-во на изделие"
                                                Binding="{Binding QuantityPerItem}"
                                                Width="160"
                                                MinWidth="130"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Основной"
                                                Binding="{Binding IsMainMaterial}"
                                                Width="120"
                                                MinWidth="90"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Форма" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Модель" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Models}"
                                      SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Материал" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Materials}"
                                      SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Количество на изделие" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormQuantityPerItem, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <CheckBox Content="Основной материал"
                                      IsChecked="{Binding FormIsMainMaterial, Mode=TwoWay}"
                                      Style="{StaticResource AppCheckBoxStyle}"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Добавить"
                                        Command="{Binding AddCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"/>

                                <Button Content="Изменить"
                                        Command="{Binding UpdateCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>

                                <Button Content="Удалить"
                                        Command="{Binding DeleteCommand}"
                                        Style="{StaticResource DangerButtonStyle}"/>

                                <Button Content="Очистить"
                                        Command="{Binding ClearCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StatusBorderStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
