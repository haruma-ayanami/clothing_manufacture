<Page x:Class="clothing_manufacture.Views.ProductionTasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Производственные задания"
      Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <ResourceDictionary Source="/Resources/AppStyles.xaml"/>
    </Page.Resources>

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderCardStyle}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Обновить"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="110"
                        Margin="12,0,0,0"/>

                <StackPanel>
                    <TextBlock Text="Производственные задания" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Планирование производства по заказу, коллекции или ассортиментному плану." Style="{StaticResource PageSubtitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="390" MinWidth="350" MaxWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Список" Style="{StaticResource SectionTitleStyle}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ProductionTasks}"
                              SelectedItem="{Binding SelectedProductionTask, Mode=TwoWay}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="70"
                                                MinWidth="60"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Номер задания"
                                                Binding="{Binding TaskNumber}"
                                                Width="170"
                                                MinWidth="130"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Дата создания"
                                                Binding="{Binding CreationDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                Width="140"
                                                MinWidth="110"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Источник"
                                                Binding="{Binding LaunchSource}"
                                                Width="170"
                                                MinWidth="130"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Статус"
                                                Binding="{Binding Status}"
                                                Width="130"
                                                MinWidth="100"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                            <DataGridTextColumn Header="Планировщик"
                                                Binding="{Binding PlannerEmployee.Person.FullName}"
                                                Width="250"
                                                MinWidth="180"
                                                ElementStyle="{StaticResource DataGridTextBlockStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Форма" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Номер задания" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormTaskNumber, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Дата создания" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding FormCreationDate, Mode=TwoWay}"
                                        Style="{StaticResource AppDatePickerStyle}"/>

                            <TextBlock Text="Плановая дата начала" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding FormPlannedStartDate, Mode=TwoWay}"
                                        Style="{StaticResource AppDatePickerStyle}"/>

                            <TextBlock Text="Плановая дата окончания" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding FormPlannedEndDate, Mode=TwoWay}"
                                        Style="{StaticResource AppDatePickerStyle}"/>

                            <TextBlock Text="Источник запуска" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormLaunchSource, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Планировщик" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Employees}"
                                      SelectedItem="{Binding SelectedPlannerEmployee, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Заказ клиента" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding CustomerOrders}"
                                      SelectedItem="{Binding SelectedCustomerOrder, Mode=TwoWay}"
                                      DisplayMemberPath="OrderNumber"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Коллекция" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Collections}"
                                      SelectedItem="{Binding SelectedCollection, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Ассортиментный план" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding AssortmentPlans}"
                                      SelectedItem="{Binding SelectedAssortmentPlan, Mode=TwoWay}"
                                      DisplayMemberPath="PlanNumber"
                                      Style="{StaticResource AppComboBoxStyle}"/>

                            <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormStatus, UpdateSourceTrigger=PropertyChanged}" MaxLength="50"
                                     Style="{StaticResource AppTextBoxStyle}"/>

                            <TextBlock Text="Комментарий" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding FormComment, UpdateSourceTrigger=PropertyChanged}" MaxLength="1000" Height="90"
                                     Style="{StaticResource AppMultilineTextBoxStyle}"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Добавить"
                                        Command="{Binding AddCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"/>

                                <Button Content="Изменить"
                                        Command="{Binding UpdateCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>

                                <Button Content="Удалить"
                                        Command="{Binding DeleteCommand}"
                                        Style="{StaticResource DangerButtonStyle}"/>

                                <Button Content="Очистить"
                                        Command="{Binding ClearCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StatusBorderStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
